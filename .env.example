# ─── FinWise Environment Variables ─────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is gitignored.
#
# HOW TO GET THESE VALUES:
#   Supabase Dashboard → Project Settings → API          (for URL and keys)
#   Supabase Dashboard → Project Settings → Database     (for connection strings)
# ─────────────────────────────────────────────────────────────────────────────────


# ─── Supabase (Public — safe to expose to the browser) ───────────────────────

# Your Supabase project URL  (e.g. https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# The anon/public key — safe for browser use, enforces Row Level Security
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# The publishable key (Supabase SSR / new client libraries)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=


# ─── Supabase (Secret — server-side only, never expose to the browser) ────────

# The service_role key — BYPASSES Row Level Security. Use only in server code.
# Required for: admin storage operations, seeding, background jobs.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Storage bucket name
NEXT_PUBLIC_SUPABASE_BUCKET=


# ─── Database Connection Strings ─────────────────────────────────────────────
#
# Supabase gives you TWO connection strings per project:
#
#   1. Transaction Pooler  (port 6543) — use for RUNTIME queries (Next.js app)
#      Supabase Dashboard → Project Settings → Database → Transaction pooler
#      Add ?pgbouncer=true to the URL.
#
#   2. Direct Connection   (port 5432) — use for MIGRATIONS and scripts
#      Supabase Dashboard → Project Settings → Database → Direct connection
#      Required for DDL (CREATE TABLE, ALTER TABLE, etc.)
#
# ─────────────────────────────────────────────────────────────────────────────

# Runtime queries — Transaction Pooler (port 6543)
# Example: postgresql://postgres.xxxx:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=

# Migrations & scripts — Direct connection (port 5432)
# Example: postgresql://postgres:[PASSWORD]@db.xxxx.supabase.co:5432/postgres
DATABASE_DIRECT_URL=


# ─── Application ─────────────────────────────────────────────────────────────

# Node environment: development | production | test
NODE_ENV=development

# Base URL of the app (used for callbacks, redirects, og:url)
# In production, set to your actual domain (e.g. https://finwise.example.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ─── LINE Login (for LINE Mini App auth) ─────────────────────────────────────

# LINE Login channel credentials (LINE Developers Console → Channel settings)
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# Redirect URI registered in LINE Login channel
# Must match exactly what is set in LINE Developers Console
LINE_CALLBACK_URL=http://localhost:3000/api/auth/callback/line


# ─── AI / OpenRouter ──────────────────────────────────────────────────────────

# OpenRouter API key for receipt / bank slip OCR extraction
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model to use for OCR (can be overridden per-request)
# Example: google/gemini-2.0-flash-exp:free
OPENROUTER_OCR_MODEL=google/gemini-2.0-flash-exp:free


# ─── Supabase Storage ────────────────────────────────────────────────────────

# Names must match the buckets you created in Supabase Storage
SUPABASE_BUCKET_RECEIPTS=receipts
SUPABASE_BUCKET_BANK_SLIPS=bank-slips